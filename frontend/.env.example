# Perevoditarr frontend — environment file (frontend/ only).
#
# Copy to `frontend/.env` to configure the SvelteKit dev server on its own. For
# the combined dev workflow a single `.env` in the repo root works too — the
# Vite config reads root `.env` and `frontend/.env` (local overrides root).
#
# Only VITE_-prefixed variables are ever exposed to browser code; the other
# variables here are read solely by the dev-server config (proxy + port).

# Port the SvelteKit dev server listens on.
FRONTEND_PORT=5173

# Backend the dev server proxies /api and /sse to. Either set host + port…
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# …or override the full URL directly (takes precedence over BACKEND_HOST/PORT).
#VITE_BACKEND_URL=http://127.0.0.1:8000
