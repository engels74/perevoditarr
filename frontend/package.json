{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "bun test --conditions browser",
		"lint": "biome check .",
		"format": "biome check --write .",
		"generate:api": "uv run --project ../backend perevoditarr export-openapi --out openapi.gen.json && bunx openapi-typescript openapi.gen.json -o src/lib/api/types.gen.ts && rm openapi.gen.json"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@happy-dom/global-registrator": "^20.10.6",
		"@internationalized/date": "^3.12.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/svelte": "^5.4.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^24",
		"@unocss/extractor-svelte": "^66.7.4",
		"@unocss/preset-wind4": "^66.7.4",
		"bun-plugin-svelte": "^0.0.6",
		"openapi-typescript": "^7.13.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"unocss": "^66.7.4",
		"unocss-preset-animations": "^1.3.0",
		"unocss-preset-shadcn": "^1.0.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@lucide/svelte": "^1.22.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	}
}
